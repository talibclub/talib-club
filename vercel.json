{
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://talib-club-web.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}